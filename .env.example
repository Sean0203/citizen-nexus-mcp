# See README to know how to setup your ENV file.

# Bearer token from UEX (required for the average commodity price endpoints)
UEX_API_KEY=
# Base URL for the UEX api
UEX_BASE_URL=

# Base URL for the star-citizen.wiki api (optional; defaults to https://api.star-citizen.wiki)
# The wiki API is public and requires no token.
WIKI_BASE_URL=
