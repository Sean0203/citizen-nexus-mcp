{
  "name": "uexcorp-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for read-only access to the uexcorp.space Star Citizen API",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "uexcorp-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "gen:types": "openapi-typescript swagger-doc/uex-api-v2.1.json -o src/api/schema.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "openapi-typescript": "^7.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
