{
  "name": "citizen-nexus-mcp",
  "version": "0.1.0",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "prepublishOnly": "npm run build",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sean0203/citizen-nexus-mcp.git"
  },
  "description": "MCP server for read-only access to the uex and star citizen wiki APIs.",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "bin": {
    "citizen-nexus-mcp": "dist/index.js"
  },
  "scripts": {
    "gen:types": "npm run gen:types:*",
    "gen:types:uex": "openapi-typescript swagger-doc/uex-api-v2.1.json -o src/api/uex/schema.ts",
    "gen:types:wiki": "openapi-typescript swagger-doc/starcitizen-wiki-openapi.yaml -o src/api/wiki/schema.ts",
    "prettier:check": "npx prettier --check .",
    "prettier:fix": "npx prettier --write .",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "clean": "rimraf dist coverage",
    "prebuild": "npm run clean",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev:inspect": "npx @modelcontextprotocol/inspector npx tsx --inspect-brk=9230 src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "fuse.js": "^7.4.2",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "openapi-typescript": "^7.0.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
